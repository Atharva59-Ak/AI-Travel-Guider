# Google Gemini AI API Key
# Get your API key from: https://makersuite.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
# Optional model override for /api/itinerary
GEMINI_MODEL=gemini-2.5-flash

# NVIDIA API (optional, used first for /api/itinerary when present)
# Get your key from: https://build.nvidia.com/
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_MODEL=google/gemma-3n-e4b-it
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# IRCTC Railway API Key (RapidAPI)
# Get your API key from: https://rapidapi.com/apiashish/api/irctc-api2
RAILWAY_RAPIDAPI_KEY=your_railway_rapidapi_key_here
RAILWAY_RAPIDAPI_HOST=irctc1.p.rapidapi.com

# IndianRailAPI (preferred railway provider)
# Get your key from: https://indianrailapi.com/developers
INDIANRAILAPI_KEY=your_indianrailapi_key_here
INDIANRAILAPI_BASE_URL=https://indianrailapi.com/api/v2

# Hotels.com API via RapidAPI (for real hotel data)
# Get your key from: https://rapidapi.com/apidojo/api/hotels4
HOTEL_RAPIDAPI_KEY=your_hotel_rapidapi_key_here

# OpenWeather API Key (for real weather data in /api/weather)
# Get your API key from: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# JWT secret for bearer token auth support on protected APIs
JWT_SECRET=replace_with_a_long_random_secret
